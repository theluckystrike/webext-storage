{
  "name": "@theluckystrike/webext-storage",
  "version": "0.1.0",
  "description": "Typed Chrome storage wrapper with schema validation. Part of @zovo/webext.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chrome",
    "extension",
    "storage",
    "typed",
    "typescript",
    "webextension",
    "browser-extension",
    "schema",
    "validation"
  ],
  "author": "theluckystrike",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/webext-storage.git"
  },
  "homepage": "https://zovo.one",
  "bugs": {
    "url": "https://github.com/theluckystrike/webext-storage/issues"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
